# 1. Go to your project directory
cd aivision-admin-bot

# 2. Install dependencies (this creates package-lock.json)
npm install

# 3. Verify package-lock.json exists
ls -la package-lock.json

# 4. Add the new files to git
git add nixpacks.toml railway.toml package-lock.json package.json

# 5. Check what's being committed
git status

# 6. Commit the changes
git commit -m "Fix Railway deployment: add nixpacks.toml and package-lock.json"

# 7. Push to GitHub
git push origin main
